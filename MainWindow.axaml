<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="1200"
        d:DesignHeight="860"
        x:Class="CrawtaDesktop.MainWindow"
        Title="Crawta"
        Background="#0D0D0D"
        Width="1200"
        Height="860"
        MinWidth="920"
        MinHeight="700">
  <Grid RowDefinitions="Auto,*">
    <Border Background="#101010" BorderBrush="#252525" BorderThickness="0,0,0,1" Padding="24,16">
      <Grid ColumnDefinitions="Auto,*,Auto,Auto">
        <Button Grid.Column="0" Content="Crawta" Click="ScrollToTopClick" Classes="navButton" />
        <Button Grid.Column="2" Content="MUSIC" Click="ScrollToMusicClick" Classes="navButton" Margin="0,0,16,0" />
        <Button Grid.Column="3" Content="NEWSLETTER" Click="ScrollToNewsletterClick" Classes="navButton" />
      </Grid>
    </Border>

    <ScrollViewer Grid.Row="1" Name="MainScrollViewer">
      <StackPanel Spacing="0">
        <Grid Height="520">
          <Image Source="avares://CrawtaDesktop/Assets/hero-bg-2.JPG" Stretch="UniformToFill" />
          <Border Background="#660D0D0D" />
          <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,56">
            <TextBlock Name="HeroTitleText" Text="Crawta" Classes="displayTitle" FontSize="84" HorizontalAlignment="Center" />
            <TextBlock Text="Grunge  ·  Indie  ·  Electronic" Foreground="#777777" FontSize="20" HorizontalAlignment="Center" />
          </StackPanel>
        </Grid>

        <StackPanel Name="MusicSection" Margin="48,56,48,0" Spacing="16">
          <TextBlock Text="Discography" Foreground="#FF8C5A" FontSize="18" FontWeight="SemiBold" />
          <TextBlock Text="Latest Demos" Name="SectionTitleText" Classes="displayTitle" FontSize="44" />
          <TextBlock Text="Grunge  ·  Indie" Foreground="#777777" FontSize="18" />

          <Border Background="#181818" BorderBrush="#252525" BorderThickness="1" Padding="16" Margin="0,8,0,12">
            <StackPanel Spacing="10">
              <TextBlock Text="Now Playing" Foreground="#FF8C5A" FontSize="14" FontWeight="SemiBold" />
              <TextBlock Name="NowPlayingText" Text="Select a track" Foreground="#F0F0F0" FontSize="20" />
              <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                <Button Name="PlayerToggleButton" Grid.Column="0" Content="Play" Click="PlayerToggleClick" Classes="primaryButton" Width="90" />
                <Slider Name="PlayerProgressSlider" Grid.Column="1" Minimum="0" Maximum="1" ValueChanged="PlayerProgressChanged" />
                <TextBlock Name="PlayerTimeText" Grid.Column="2" Text="0:00 / 0:00" VerticalAlignment="Center" Foreground="#777777" />
              </Grid>
            </StackPanel>
          </Border>

          <Border Background="#141414" BorderBrush="#252525" BorderThickness="1" Padding="16">
            <StackPanel Spacing="10">
              <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,6">
                <Button Grid.Column="0" Content="01  Mother Earth" Click="PlayMotherEarthClick" Classes="trackButton" />
                <TextBlock Grid.Column="2" Text="9.1K" VerticalAlignment="Center" Foreground="#777777" />
              </Grid>
              <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,6">
                <Button Grid.Column="0" Content="02  Complacent" Click="PlayComplacentClick" Classes="trackButton" />
                <TextBlock Grid.Column="2" Text="42.7K" VerticalAlignment="Center" Foreground="#777777" />
              </Grid>
              <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,6">
                <Button Grid.Column="0" Content="03  White Noise" Click="PlayWhiteNoiseClick" Classes="trackButton" />
                <TextBlock Grid.Column="2" Text="15.8K" VerticalAlignment="Center" Foreground="#777777" />
              </Grid>
              <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,6">
                <Button Grid.Column="0" Content="04  Iris" Click="PlayIrisClick" Classes="trackButton" />
                <TextBlock Grid.Column="2" Text="7.3K" VerticalAlignment="Center" Foreground="#777777" />
              </Grid>
            </StackPanel>
          </Border>

          <TextBlock Text="Previous Music" Foreground="#F0F0F0" FontSize="36" FontWeight="Bold" Margin="0,12,0,0" />
          <TextBlock Text="Electronic" Foreground="#777777" FontSize="18" />
          <Border Background="#141414" BorderBrush="#252525" BorderThickness="1" Padding="16">
            <StackPanel Spacing="10">
              <Grid ColumnDefinitions="Auto,*,Auto,Auto" Margin="0,6">
                <Button Grid.Column="0" Content="01  Prospects" Click="PlayProspectsClick" Classes="trackButton" />
                <Button Grid.Column="2" Content="Spotify" Click="OpenProspectsSpotifyClick" Classes="chipButton" />
                <TextBlock Grid.Column="3" Text="42.7K" Margin="12,0,0,0" VerticalAlignment="Center" Foreground="#777777" />
              </Grid>
              <Grid ColumnDefinitions="Auto,*,Auto,Auto" Margin="0,6">
                <Button Grid.Column="0" Content="02  Hyph Mngo edit" Click="PlayHyphMngoClick" Classes="trackButton" />
                <Button Grid.Column="2" Content="SoundCloud" Click="OpenHyphMngoSoundCloudClick" Classes="chipButton" />
                <TextBlock Grid.Column="3" Text="26.4K" Margin="12,0,0,0" VerticalAlignment="Center" Foreground="#777777" />
              </Grid>
              <Grid ColumnDefinitions="Auto,*,Auto,Auto" Margin="0,6">
                <Button Grid.Column="0" Content="03  Requiem" Click="PlayRequiemClick" Classes="trackButton" />
                <Button Grid.Column="2" Content="SoundCloud" Click="OpenRequiemSoundCloudClick" Classes="chipButton" />
                <TextBlock Grid.Column="3" Text="4.3K" Margin="12,0,0,0" VerticalAlignment="Center" Foreground="#777777" />
              </Grid>
            </StackPanel>
          </Border>

          <WrapPanel Orientation="Horizontal" Margin="0,20,0,0">
            <Button Content="Listen on SoundCloud" Click="OpenMainSoundCloudClick" Classes="chipButton" Margin="0,0,12,12" />
            <Button Content="Listen on Spotify" Click="OpenMainSpotifyClick" Classes="chipButton" Margin="0,0,12,12" />
          </WrapPanel>
        </StackPanel>

        <Border Name="NewsletterSection" Margin="48,56,48,0" Background="#181818" BorderBrush="#252525" BorderThickness="1" Padding="32">
          <StackPanel Spacing="24">
            <WrapPanel Orientation="Horizontal">
              <StackPanel Spacing="8" Width="560" Margin="0,0,24,20">
                <TextBlock Text="Stay in the loop" Foreground="#FF8C5A" FontSize="18" FontWeight="SemiBold" />
                <TextBlock Text="Something new is happening." Name="NewsletterTitleText" Classes="displayTitle" FontSize="42" />
                <TextBlock
                  Text="Join the list for early track drops, behind-the-scenes, and show announcements — no noise, just signal."
                  Foreground="#777777"
                  FontSize="16"
                  TextWrapping="Wrap"
                  MaxWidth="560" />
              </StackPanel>

              <StackPanel Spacing="10" Width="300" Margin="0,0,0,20">
                <TextBox Name="EmailBox" PlaceholderText="your@email.com" />
                <Button Name="SubscribeButton" Content="Subscribe" Click="SubscribeClick" Classes="primaryButton" />
                <TextBlock Name="SignupNoteText" Text="No spam, unsubscribe anytime." Foreground="#777777" FontSize="13" />
                <TextBlock Name="SuccessText" Text="You're in. Thanks for joining." IsVisible="False" Foreground="#FF8C5A" FontSize="16" />
              </StackPanel>
            </WrapPanel>

            <WrapPanel Orientation="Horizontal">
              <Button Content="Instagram" Click="OpenInstagramClick" Classes="chipButton" Margin="0,0,12,12" />
              <Button Content="SoundCloud" Click="OpenMainSoundCloudClick" Classes="chipButton" Margin="0,0,12,12" />
            </WrapPanel>
          </StackPanel>
        </Border>

        <Border BorderBrush="#252525" BorderThickness="0,1,0,0" Margin="0,32,0,0" Padding="48,20">
          <Grid ColumnDefinitions="Auto,*">
            <TextBlock Text="Crawta" Classes="displayTitle" FontSize="20" Foreground="#777777" />
            <TextBlock Grid.Column="1" Name="FooterCopyText" HorizontalAlignment="Right" Foreground="#777777" FontSize="14" />
          </Grid>
        </Border>
      </StackPanel>
    </ScrollViewer>
  </Grid>

  <Window.Styles>
    <Style Selector="TextBlock.displayTitle">
      <Setter Property="Foreground" Value="#F0F0F0" />
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="FontFamily" Value="avares://CrawtaDesktop/Assets/fonts/SamuraiShadow.otf#Samurai Shadow, Inter" />
    </Style>
    <Style Selector="Button.navButton">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="#F0F0F0" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="FontSize" Value="14" />
      <Setter Property="Padding" Value="8,4" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="FontFamily" Value="avares://CrawtaDesktop/Assets/fonts/SamuraiShadow.otf#Samurai Shadow" />
    </Style>
    <Style Selector="Button.trackButton">
      <Setter Property="Background" Value="#141414" />
      <Setter Property="Foreground" Value="#F0F0F0" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="FontSize" Value="16" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="HorizontalAlignment" Value="Left" />
    </Style>
    <Style Selector="Button.chipButton">
      <Setter Property="Background" Value="#141414" />
      <Setter Property="Foreground" Value="#F0F0F0" />
      <Setter Property="BorderBrush" Value="#252525" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding" Value="12,8" />
      <Setter Property="Cursor" Value="Hand" />
    </Style>
    <Style Selector="Button.primaryButton">
      <Setter Property="Background" Value="#FF8C5A" />
      <Setter Property="Foreground" Value="#0D0D0D" />
      <Setter Property="BorderBrush" Value="#FF8C5A" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="12,8" />
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="FontFamily" Value="avares://CrawtaDesktop/Assets/fonts/SamuraiShadow.otf#Samurai Shadow, Inter" />
    </Style>
    <Style Selector="TextBox">
      <Setter Property="Background" Value="#1E1E1E" />
      <Setter Property="Foreground" Value="#F0F0F0" />
      <Setter Property="BorderBrush" Value="#252525" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding" Value="10,8" />
    </Style>
  </Window.Styles>
</Window>
